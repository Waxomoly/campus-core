<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_organisasi_list" model="ir.ui.view">
        <field name="name">campus.organisasi.list</field>
        <field name="model">campus.organisasi</field>
        <field name="arch" type="xml">
            <list string="Organisasi">
                <field name="kode"/>
                <field name="name"/>
                <field name="tipe_id"/>
                <field name="ketua_id"/>
                <field name="ketua_jurusan_id"/>
                <field name="pembina_id" optional="show"/>
                <field name="jumlah_anggota"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'aktif'"
                       decoration-danger="state == 'nonaktif'"/>
            </list>
        </field>
    </record>

    <record id="view_campus_organisasi_form" model="ir.ui.view">
        <field name="name">campus.organisasi.form</field>
        <field name="model">campus.organisasi</field>
        <field name="arch" type="xml">
            <form string="Organisasi">
                <header>
                    <button name="action_set_nonaktif" string="Non-Aktifkan" type="object" class="btn-danger"
                            invisible="state == 'nonaktif'" groups="campus_core.group_campus_lecturer"/>
                    <button name="action_set_aktif" string="Aktifkan" type="object" class="oe_highlight"
                            invisible="state == 'aktif'" groups="campus_core.group_campus_lecturer"/>
                    <field name="state" widget="statusbar" statusbar_visible="aktif,nonaktif"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_proposal" icon="fa-file-text-o">
                            <field name="proposal_count" widget="statinfo" string="Proposal"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="kode"/>
                            <field name="name"/>
                            <field name="tipe_id" required="1"/>
                            <field name="ketua_id" required="1"/>
                        </group>
                        <group>
                            <field name="pembina_id"/>
                            <field name="jumlah_anggota"/>
                            <field name="deskripsi"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Struktur Organisasi" name="anggota">
                            <field name="anggota_ids">
                                <list editable="bottom">
                                    <field name="mahasiswa_id"/>
                                    <field name="jabatan_id" required="1"
                                           domain="['|', ('tipe_id', '=', False), ('tipe_id', '=', parent.tipe_id)]"/>
                                </list>
                            </field>
                        </page>
                        <page string="Proposal Kegiatan" name="proposal">
                            <field name="proposal_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="judul"/>
                                    <field name="tanggal_kegiatan"/>
                                    <field name="anggaran"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_organisasi_search" model="ir.ui.view">
        <field name="name">campus.organisasi.search</field>
        <field name="model">campus.organisasi</field>
        <field name="arch" type="xml">
            <search string="Cari Organisasi">
                <field name="kode"/>
                <field name="name"/>
                <field name="tipe_id"/>
                <field name="ketua_id"/>
                <field name="pembina_id"/>
                <filter name="filter_aktif" string="Aktif" domain="[('state', '=', 'aktif')]"/>
                <group>
                    <filter name="group_tipe" string="Tipe Organisasi" context="{'group_by': 'tipe_id'}"/>
                    <filter name="group_pembina" string="Dosen Pembina" context="{'group_by': 'pembina_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_organisasi" model="ir.actions.act_window">
        <field name="name">Organisasi</field>
        <field name="res_model">campus.organisasi</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_campus_organisasi_root" name="Organisasi"
              parent="campus_core.menu_campus_root" sequence="40"/>
    <menuitem id="menu_campus_organisasi" name="Data Organisasi"
              parent="menu_campus_organisasi_root"
              action="action_campus_organisasi" sequence="10"
              groups="campus_core.group_campus_lecturer"/>
</odoo>
