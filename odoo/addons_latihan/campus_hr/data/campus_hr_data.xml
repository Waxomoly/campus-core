<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ==================== TIPE ORGANISASI ==================== -->
        <record id="tipe_pelayanan_mahasiswa" model="campus.organisasi.tipe">
            <field name="kode">PM</field>
            <field name="name">Pelayanan Mahasiswa</field>
        </record>
        <record id="tipe_bem" model="campus.organisasi.tipe">
            <field name="kode">BEM</field>
            <field name="name">Badan Eksekutif Mahasiswa (BEM)</field>
        </record>
        <record id="tipe_hima" model="campus.organisasi.tipe">
            <field name="kode">HIMA</field>
            <field name="name">Himpunan Mahasiswa (HIMA)</field>
        </record>
        <record id="tipe_bpmf" model="campus.organisasi.tipe">
            <field name="kode">BPMF</field>
            <field name="name">Badan Perwakilan Mahasiswa Fakultas (BPMF)</field>
        </record>
        <record id="tipe_pers" model="campus.organisasi.tipe">
            <field name="kode">PERS</field>
            <field name="name">Pers Mahasiswa</field>
        </record>

        <!-- ==================== JABATAN UMUM (semua tipe) ==================== -->
        <record id="jabatan_wakil_ketua" model="campus.jabatan">
            <field name="sequence">10</field>
            <field name="name">Wakil Ketua</field>
        </record>
        <record id="jabatan_sekretaris" model="campus.jabatan">
            <field name="sequence">20</field>
            <field name="name">Sekretaris</field>
        </record>
        <record id="jabatan_bendahara" model="campus.jabatan">
            <field name="sequence">30</field>
            <field name="name">Bendahara</field>
        </record>
        <record id="jabatan_anggota" model="campus.jabatan">
            <field name="sequence">99</field>
            <field name="name">Anggota</field>
        </record>

        <!-- ==================== JABATAN KHUSUS HIMA ==================== -->
        <record id="jabatan_hima_sekum" model="campus.jabatan">
            <field name="sequence">21</field>
            <field name="name">Sekretaris Umum</field>
            <field name="tipe_id" ref="tipe_hima"/>
        </record>

        <!-- ==================== JABATAN KHUSUS BEM ==================== -->
        <record id="jabatan_bem_sek1" model="campus.jabatan">
            <field name="sequence">21</field>
            <field name="name">Sekretaris 1</field>
            <field name="tipe_id" ref="tipe_bem"/>
        </record>
        <record id="jabatan_bem_sek2" model="campus.jabatan">
            <field name="sequence">22</field>
            <field name="name">Sekretaris 2</field>
            <field name="tipe_id" ref="tipe_bem"/>
        </record>

        <!-- ===== JABATAN KEPANITIAAN: BPH (is_bph=True) ===== -->
        <record id="jab_panitia_wakil_ketua" model="campus.jabatan.panitia">
            <field name="sequence">10</field>
            <field name="name">Wakil Ketua</field>
            <field name="is_bph" eval="True"/>
        </record>
        <record id="jab_panitia_sekretaris" model="campus.jabatan.panitia">
            <field name="sequence">20</field>
            <field name="name">Sekretaris</field>
            <field name="is_bph" eval="True"/>
        </record>
        <record id="jab_panitia_bendahara" model="campus.jabatan.panitia">
            <field name="sequence">30</field>
            <field name="name">Bendahara</field>
            <field name="is_bph" eval="True"/>
        </record>

        <!-- ===== JABATAN KEPANITIAAN: DIVISI BIASA (is_bph=False) ===== -->
        <record id="jab_panitia_koordinator" model="campus.jabatan.panitia">
            <field name="sequence">40</field>
            <field name="name">Koordinator</field>
        </record>
        <record id="jab_panitia_wakil_koordinator" model="campus.jabatan.panitia">
            <field name="sequence">50</field>
            <field name="name">Wakil Koordinator</field>
        </record>
        <record id="jab_panitia_anggota" model="campus.jabatan.panitia">
            <field name="sequence">60</field>
            <field name="name">Anggota</field>
        </record>

        <!-- ==================== DIVISI KEPANITIAAN ==================== -->
        <record id="divisi_bph" model="campus.divisi">
            <field name="sequence">1</field>
            <field name="name">BPH (Badan Pengurus Harian)</field>
            <field name="is_bph" eval="True"/>
        </record>
        <record id="divisi_acara" model="campus.divisi">
            <field name="sequence">10</field>
            <field name="name">Acara</field>
        </record>
        <record id="divisi_humas" model="campus.divisi">
            <field name="sequence">20</field>
            <field name="name">Hubungan Masyarakat (Humas)</field>
        </record>
        <record id="divisi_konsumsi" model="campus.divisi">
            <field name="sequence">30</field>
            <field name="name">Konsumsi</field>
        </record>
        <record id="divisi_perlengkapan" model="campus.divisi">
            <field name="sequence">40</field>
            <field name="name">Perlengkapan</field>
        </record>
        <record id="divisi_dokumentasi" model="campus.divisi">
            <field name="sequence">50</field>
            <field name="name">Dokumentasi</field>
        </record>
        <record id="divisi_dana_usaha" model="campus.divisi">
            <field name="sequence">60</field>
            <field name="name">Dana Usaha</field>
        </record>
    </data>
</odoo>
