<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_proposal" model="ir.actions.report">
        <field name="name">Proposal Kegiatan</field>
        <field name="model">campus.proposal</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">campus_hr.report_proposal_document</field>
        <field name="report_file">campus_hr.report_proposal_document</field>
        <field name="binding_model_id" ref="model_campus_proposal"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_proposal_document">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <t t-foreach="docs" t-as="doc">
                    <div class="page">
                        <!-- Judul -->
                        <div style="text-align: center; margin-bottom: 16px;">
                            <h2 style="margin: 0; font-size: 16pt; text-transform: uppercase;">
                                Proposal Kegiatan
                            </h2>
                            <p style="margin: 4px 0; font-size: 10pt; color: #555;">
                                <t t-esc="doc.name"/>
                            </p>
                        </div>

                        <!-- Info Header -->
                        <table style="width: 100%; font-size: 10pt; margin-bottom: 16px; border-collapse: collapse;">
                            <tr>
                                <td style="width: 50%; vertical-align: top; padding: 2px 0;">
                                    <table>
                                        <tr>
                                            <td style="width: 120px; font-weight: bold;">Judul Kegiatan</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.judul"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Organisasi</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.organisasi_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Ketua Panitia</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.ketua_panitia_id.name or '-'"/></td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="width: 50%; vertical-align: top; padding: 2px 0;">
                                    <table>
                                        <tr>
                                            <td style="width: 120px; font-weight: bold;">Tanggal Kegiatan</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><span t-field="doc.tanggal_kegiatan" t-options='{"format": "dd MMMM yyyy"}'/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Anggaran</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td>Rp <t t-esc="'{:,.0f}'.format(doc.anggaran)"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Status</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="dict(doc._fields['state'].selection).get(doc.state)"/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- Deskripsi -->
                        <div t-if="doc.deskripsi" style="font-size: 10pt; margin-bottom: 16px;">
                            <p style="font-weight: bold; margin: 0 0 4px 0;">Deskripsi Kegiatan:</p>
                            <p style="margin: 0; text-align: justify;"><t t-esc="doc.deskripsi"/></p>
                        </div>

                        <!-- Tabel Kepanitiaan -->
                        <p style="font-weight: bold; font-size: 10pt; margin: 0 0 4px 0;">Struktur Kepanitiaan</p>
                        <table style="width: 100%; border-collapse: collapse; font-size: 10pt;">
                            <thead>
                                <tr style="background-color: #2c3e50; color: white;">
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 40px;">No</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: left;">Divisi</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: left;">Nama Mahasiswa</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: left;">Jabatan</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.panitia_ids" t-as="line">
                                    <tr t-attf-style="background-color: {{ 'white' if line_index % 2 == 0 else '#f9f9f9' }};">
                                        <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                            <t t-esc="line_index + 1"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px;">
                                            <t t-esc="line.divisi_id.name or '-'"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px;">
                                            <t t-esc="line.mahasiswa_id.name"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px;">
                                            <t t-esc="line.jabatan_id.name"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Tanda Tangan -->
                        <table style="width: 100%; margin-top: 40px; font-size: 10pt; text-align: center;">
                            <tr>
                                <td style="width: 50%;">
                                    Ketua Panitia,
                                    <div style="margin-top: 60px;">
                                        <span style="font-weight: bold; border-top: 1px solid black; padding-top: 4px;">
                                            <t t-esc="doc.ketua_panitia_id.name or '________________'"/>
                                        </span>
                                    </div>
                                </td>
                                <td style="width: 50%;">
                                    Menyetujui,<br/>Dosen Pembina,
                                    <div style="margin-top: 60px;">
                                        <span style="font-weight: bold; border-top: 1px solid black; padding-top: 4px;">
                                            <t t-esc="doc.pembina_id.name or '________________'"/>
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
