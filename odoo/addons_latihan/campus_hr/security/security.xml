<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tidak ada lagi group "Organisasi Manager" terpisah.
         Hak pengelola (approve/reject proposal + CRUD Data Organisasi &
         Master Data) menempel langsung pada Role Lecturer (Dosen).
         Role Student hanya bisa read Organisasi/Master Data dan
         membuat/mengubah Proposal Kegiatan + Struktur Kepanitiaan. -->

    <record id="rule_proposal_own" model="ir.rule">
        <field name="name">Proposal: user hanya melihat miliknya</field>
        <field name="model_id" ref="model_campus_proposal"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_proposal_manager" model="ir.rule">
        <field name="name">Proposal: Lecturer melihat semua</field>
        <field name="model_id" ref="model_campus_proposal"/>
        <field name="groups" eval="[(4, ref('campus_core.group_campus_lecturer'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
