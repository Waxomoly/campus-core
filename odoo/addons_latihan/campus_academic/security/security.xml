<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="privilege_academic_access" model="res.groups.privilege">
        <field name="name">Academic Access</field>
        <field name="category_id" ref="campus_core.module_category_campus"/>
        <field name="sequence">20</field>
        <field name="placeholder">Non-Manager</field>
    </record>

    <record id="group_academic_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_academic_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_transkrip_own" model="ir.rule">
        <field name="name">Transkrip: user hanya melihat miliknya</field>
        <field name="model_id" ref="model_campus_transkrip"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_transkrip_manager" model="ir.rule">
        <field name="name">Transkrip: manager melihat semua</field>
        <field name="model_id" ref="model_campus_transkrip"/>
        <field name="groups" eval="[(4, ref('group_academic_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
