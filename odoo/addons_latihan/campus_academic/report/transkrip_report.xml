<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_transkrip" model="ir.actions.report">
        <field name="name">Transkrip Nilai</field>
        <field name="model">campus.transkrip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">campus_academic.report_transkrip_document</field>
        <field name="report_file">campus_academic.report_transkrip_document</field>
        <field name="binding_model_id" ref="model_campus_transkrip"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_transkrip_document">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <t t-foreach="docs" t-as="doc">
                    <div class="page">
                        <!-- Judul -->
                        <div style="text-align: center; margin-bottom: 16px;">
                            <h2 style="margin: 0; font-size: 16pt; text-transform: uppercase;">
                                Transkrip Nilai
                            </h2>
                            <p style="margin: 4px 0; font-size: 10pt; color: #555;">
                                <t t-esc="doc.name"/>
                            </p>
                        </div>

                        <!-- Info Header -->
                        <table style="width: 100%; font-size: 10pt; margin-bottom: 16px; border-collapse: collapse;">
                            <tr>
                                <td style="width: 50%; vertical-align: top; padding: 2px 0;">
                                    <table>
                                        <tr>
                                            <td style="width: 120px; font-weight: bold;">Mahasiswa</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.mahasiswa_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">NIM</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.mahasiswa_id.nim"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Status</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="dict(doc._fields['status_kelulusan'].selection).get(doc.status_kelulusan)"/></td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="width: 50%; vertical-align: top; padding: 2px 0;">
                                    <table>
                                        <tr>
                                            <td style="width: 120px; font-weight: bold;">Fakultas</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.mahasiswa_id.fakultas_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Program Studi</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.mahasiswa_id.prodi_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Jurusan</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.mahasiswa_id.jurusan_id.name or '-'"/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- Tabel Nilai -->
                        <p style="font-weight: bold; font-size: 10pt; margin: 0 0 4px 0;">Daftar Nilai</p>
                        <table style="width: 100%; border-collapse: collapse; font-size: 10pt;">
                            <thead>
                                <tr style="background-color: #2c3e50; color: white;">
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 40px;">No</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: left;">Kode MK</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: left;">Mata Kuliah</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 50px;">SKS</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 60px;">Angka</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 60px;">Huruf</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 60px;">Bobot</th>
                                    <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 60px;">Mutu</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.nilai_ids" t-as="line">
                                    <tr t-attf-style="background-color: {{ 'white' if line_index % 2 == 0 else '#f9f9f9' }};">
                                        <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                            <t t-esc="line_index + 1"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px;">
                                            <t t-esc="line.mata_kuliah_id.kode_mk"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px;">
                                            <t t-esc="line.mata_kuliah_id.name"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                            <t t-esc="line.sks"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                            <t t-esc="line.nilai_angka"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                            <t t-esc="line.nilai_huruf"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                            <t t-esc="line.bobot"/>
                                        </td>
                                        <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                            <t t-esc="line.nilai_mutu"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color: #ecf0f1; font-weight: bold;">
                                    <td colspan="3" style="border: 1px solid #ccc; padding: 5px 8px; text-align: right;">Total SKS</td>
                                    <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;"><t t-esc="doc.total_sks"/></td>
                                    <td colspan="3" style="border: 1px solid #ccc; padding: 5px 8px; text-align: right;">IPK</td>
                                    <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;"><t t-esc="'%.2f' % doc.ipk"/></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Tanda Tangan -->
                        <div style="margin-top: 40px; text-align: right; font-size: 10pt;">
                            <p style="margin: 0;">Mengetahui,</p>
                            <p style="margin: 0; margin-top: 4px;">Ketua Program Studi,</p>
                            <div style="margin-top: 60px;">
                                <span style="font-weight: bold; border-top: 1px solid black; display: inline-block; min-width: 180px; text-align: center; padding-top: 4px;">
                                    <t t-esc="doc.mahasiswa_id.prodi_id.name or '________________'"/>
                                </span>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
