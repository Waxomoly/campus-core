<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_mahasiswa_list" model="ir.ui.view">
        <field name="name">campus.mahasiswa.list</field>
        <field name="model">campus.mahasiswa</field>
        <field name="arch" type="xml">
            <list string="Daftar Mahasiswa">
                <field name="nim"/>
                <field name="name"/>
                <field name="email"/>
                <field name="jurusan_id"/>
                <field name="angkatan"/>
                <field name="semester_aktif"/>
                <field name="ipk"/>
                <field name="status_kelulusan" widget="badge"
                       decoration-success="status_kelulusan == 'lulus'"
                       decoration-warning="status_kelulusan == 'belum'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'aktif'"
                       decoration-info="status == 'lulus'"
                       decoration-warning="status == 'cuti'"
                       decoration-danger="status == 'non_aktif'"/>
            </list>
        </field>
    </record>

    <record id="view_campus_mahasiswa_form" model="ir.ui.view">
        <field name="name">campus.mahasiswa.form</field>
        <field name="model">campus.mahasiswa</field>
        <field name="arch" type="xml">
            <form string="Form Mahasiswa">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nama Mahasiswa"/></h1>
                    </div>
                    <group>
                        <group string="Identitas">
                            <field name="nim" required="1"/>
                            <field name="email" required="1"/>
                            <field name="tempat_lahir" required="1"/>
                            <field name="tanggal_lahir" options="{'datepicker': {'yearRange': 'c-60:c+0'}}" required="1"/>
                            <field name="jenis_kelamin" required="1"/>
                            <field name="alamat" required="1"/>
                        </group>
                        <group string="Akademik">
                            <field name="fakultas_id" required="1"/>
                            <field name="prodi_id" required="1"/>
                            <field name="jurusan_id" required="1"/>
                            <field name="angkatan" required="1"/>
                            <field name="semester_aktif" required="1"/>
                            <field name="ipk"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <group string="Kelulusan">
                        <group>
                            <field name="total_sks_lulus"/>
                            <field name="status_kelulusan"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_mahasiswa_search" model="ir.ui.view">
        <field name="name">campus.mahasiswa.search</field>
        <field name="model">campus.mahasiswa</field>
        <field name="arch" type="xml">
            <search string="Cari Mahasiswa">
                <field name="nim"/>
                <field name="name"/>
                <field name="email"/>
                <field name="prodi_id"/>
                <field name="jurusan_id"/>
                <field name="fakultas_id"/>
                <field name="angkatan"/>
                <filter name="filter_aktif" string="Aktif" domain="[('status', '=', 'aktif')]"/>
                <filter name="filter_lulus" string="Sudah Lulus" domain="[('status_kelulusan', '=', 'lulus')]"/>
                <group>
                    <filter name="group_fakultas" string="Fakultas" context="{'group_by': 'fakultas_id'}"/>
                    <filter name="group_jurusan" string="Jurusan" context="{'group_by': 'jurusan_id'}"/>
                    <filter name="group_prodi" string="Prodi" context="{'group_by': 'prodi_id'}"/>
                    <filter name="group_angkatan" string="Angkatan" context="{'group_by': 'angkatan'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_mahasiswa" model="ir.actions.act_window">
        <field name="name">Mahasiswa</field>
        <field name="res_model">campus.mahasiswa</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_campus_mahasiswa" name="Mahasiswa" parent="menu_campus_master" action="action_campus_mahasiswa" sequence="10"
          groups="campus_core.group_campus_lecturer,campus_core.group_academic_manager"/>

    <record id="action_campus_my_profile" model="ir.actions.server">
        <field name="name">Profil Saya</field>
        <field name="model_id" ref="model_campus_mahasiswa"/>
        <field name="state">code</field>
        <field name="code">
            <![CDATA[
# 1. Cek apakah user yang login punya role Manager
is_manager = env.user.has_group('campus_core.group_academic_manager')

mhs = env['campus.mahasiswa'].search([('user_id', '=', env.uid)], limit=1)
dosen = env['campus.dosen'].search([('user_id', '=', env.uid)], limit=1)

if is_manager:
    # JIKA MANAGER: Lewati pengecekan, langsung buka daftar seluruh mahasiswa (List & Form)
    action = {
        'type': 'ir.actions.act_window',
        'name': 'Daftar Mahasiswa',
        'res_model': 'campus.mahasiswa',
        'view_mode': 'list,form',
        'target': 'current',
    }
elif mhs:
    action = {
        'type': 'ir.actions.act_window',
        'name': 'Profil Saya',
        'res_model': 'campus.mahasiswa',
        'view_mode': 'form',
        'res_id': mhs.id,
        'target': 'current',
    }
elif dosen:
    action = {
        'type': 'ir.actions.act_window',
        'name': 'Profil Saya',
        'res_model': 'campus.dosen',
        'view_mode': 'form',
        'res_id': dosen.id,
        'target': 'current',
    }
else:
    action = {
        'type': 'ir.actions.client',
        'tag': 'display_notification',
        'params': {
            'title': 'Profil tidak ditemukan',
            'message': 'Akun ini belum terhubung ke data mahasiswa maupun dosen. Hubungi admin akademik.',
            'type': 'warning',
            'sticky': False,
        },
    }
            ]]>
        </field>
    </record>

    <menuitem id="menu_campus_my_profile" name="Profil Saya"
              parent="menu_campus_root" sequence="50"
              action="action_campus_my_profile"
              groups="campus_core.group_campus_student,campus_core.group_campus_lecturer"/>
</odoo>