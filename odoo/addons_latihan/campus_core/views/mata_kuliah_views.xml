<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_mata_kuliah_list" model="ir.ui.view">
        <field name="name">campus.mata_kuliah.list</field>
        <field name="model">campus.mata_kuliah</field>
        <field name="arch" type="xml">
            <list string="Daftar Mata Kuliah">
                <field name="kode_mk"/>
                <field name="name"/>
                <field name="sks"/>
                <field name="prodi_ids" widget="many2many_tags"/>
                <field name="dosen_ids" widget="many2many_tags"/>
                <field name="kelas_count"/>
            </list>
        </field>
    </record>

    <record id="view_campus_mata_kuliah_form" model="ir.ui.view">
        <field name="name">campus.mata_kuliah.form</field>
        <field name="model">campus.mata_kuliah</field>
        <field name="arch" type="xml">
            <form string="Form Mata Kuliah">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nama Mata Kuliah"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="kode_mk"/>
                            <field name="sks"/>
                            <field name="dosen_koordinator_id"/>
                            <field name="dosen_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="fakultas_ids" widget="many2many_tags" help="Kosongkan untuk semua fakultas."/>
                            <field name="prodi_ids" widget="many2many_tags" domain="[('fakultas_id', 'in', fakultas_ids or [False])]" help="Kosongkan untuk semua prodi."/>
                            <field name="jurusan_ids" widget="many2many_tags" domain="[('prodi_id', 'in', prodi_ids or [False])]" help="Kosongkan untuk semua jurusan."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Kelas &amp; Jadwal" name="kelas">
                            <field name="kelas_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="semester"/>
                                    <field name="dosen_id"/>
                                    <field name="hari"/>
                                    <field name="jam_mulai" widget="float_time"/>
                                    <field name="jam_selesai" widget="float_time"/>
                                    <field name="ruangan"/>
                                    <field name="kuota"/>
                                    <field name="terisi"/>
                                    <field name="sisa_kuota"/>
                                    <field name="is_available" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_mata_kuliah_search" model="ir.ui.view">
        <field name="name">campus.mata_kuliah.search</field>
        <field name="model">campus.mata_kuliah</field>
        <field name="arch" type="xml">
            <search string="Cari Mata Kuliah">
                <field name="kode_mk"/>
                <field name="name"/>
                <field name="prodi_ids"/>
                <field name="dosen_koordinator_id"/>
                <group>
                   <filter name="group_dosen" string="Penanggung Jawab" context="{'group_by': 'dosen_koordinator_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_mata_kuliah" model="ir.actions.act_window">
        <field name="name">Mata Kuliah</field>
        <field name="res_model">campus.mata_kuliah</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_campus_mata_kuliah" name="Mata Kuliah" parent="menu_campus_master" action="action_campus_mata_kuliah" sequence="30"/>
</odoo>
