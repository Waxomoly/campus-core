<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_campus" model="ir.module.category">
        <field name="name">Campus</field>
        <field name="sequence">20</field>
    </record>

    <record id="privilege_campus_role" model="res.groups.privilege">
        <field name="name">Campus Role</field>
        <field name="category_id" ref="module_category_campus"/>
        <field name="placeholder">Bukan pengguna Campus</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_campus_student" model="res.groups">
        <field name="name">Mahasiswa</field>
        <field name="privilege_id" ref="privilege_campus_role"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_campus_lecturer" model="res.groups">
        <field name="name">Dosen</field>
        <field name="privilege_id" ref="privilege_campus_role"/>
        <field name="implied_ids" eval="[(4, ref('group_campus_student'))]"/>
    </record>

    <record id="group_academic_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_campus_role"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_mahasiswa_own_profile" model="ir.rule">
        <field name="name">Mahasiswa: Hanya lihat profil sendiri</field>
        <field name="model_id" ref="model_campus_mahasiswa"/>
        <field name="groups" eval="[(4, ref('group_campus_student'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
    </record>
    <record id="rule_mahasiswa_manager" model="ir.rule">
        <field name="name">Mahasiswa: Manager lihat semua</field>
        <field name="model_id" ref="model_campus_mahasiswa"/>
        <field name="groups" eval="[(4, ref('group_academic_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
    <record id="rule_mahasiswa_lecturer" model="ir.rule">
        <field name="name">Mahasiswa: Dosen lihat semua</field>
        <field name="model_id" ref="model_campus_mahasiswa"/>
        <field name="groups" eval="[(4, ref('group_campus_lecturer'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_krs_own_student" model="ir.rule">
        <field name="name">KRS: Mahasiswa hanya lihat miliknya</field>
        <field name="model_id" ref="model_campus_krs"/>
        <field name="groups" eval="[(4, ref('group_campus_student'))]"/>
        <field name="domain_force">[('mahasiswa_id.user_id', '=', user.id)]</field>
    </record>
    <record id="rule_krs_manager" model="ir.rule">
        <field name="name">KRS: Manager lihat semua</field>
        <field name="model_id" ref="model_campus_krs"/>
        <field name="groups" eval="[(4, ref('group_academic_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
    <record id="rule_krs_lecturer" model="ir.rule">
        <field name="name">KRS: Dosen lihat semua</field>
        <field name="model_id" ref="model_campus_krs"/>
        <field name="groups" eval="[(4, ref('group_campus_lecturer'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>