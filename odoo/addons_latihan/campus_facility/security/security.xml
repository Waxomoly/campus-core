<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_facility_manager" model="res.groups">
        <field name="name">Facility Manager</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_booking_own" model="ir.rule">
        <field name="name">Booking: user hanya melihat miliknya</field>
        <field name="model_id" ref="model_campus_facility_booking"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
    </record>

    <record id="rule_booking_manager" model="ir.rule">
        <field name="name">Booking: manager melihat semua</field>
        <field name="model_id" ref="model_campus_facility_booking"/>
        <field name="groups" eval="[(4, ref('group_facility_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
