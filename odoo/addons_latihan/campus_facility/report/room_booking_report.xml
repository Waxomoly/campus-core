<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_room_booking" model="ir.actions.report">
        <field name="name">Bukti Reservasi Ruangan</field>
        <field name="model">campus.room.booking</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">campus_facility.report_room_booking_doc</field>
        <field name="report_file">campus_facility.report_room_booking_doc</field>
        <field name="binding_model_id" eval="False"/>
    </record>

    <template id="report_room_booking_doc">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <t t-foreach="docs" t-as="doc">
                    <div class="page">
                        <!-- Judul -->
                        <div style="text-align: center; margin-bottom: 16px;">
                            <h2 style="margin: 0; font-size: 16pt; text-transform: uppercase;">
                                Bukti Reservasi Ruangan
                            </h2>
                            <p style="margin: 4px 0; font-size: 10pt; color: #555;">
                                <t t-esc="doc.name"/>
                            </p>
                        </div>

                        <!-- Info Header -->
                        <table style="width: 100%; font-size: 10pt; margin-bottom: 16px; border-collapse: collapse;">
                            <tr>
                                <td style="width: 50%; vertical-align: top; padding: 2px 0;">
                                    <table>
                                        <tr>
                                            <td style="width: 120px; font-weight: bold;">Ruangan</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.room_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Peminjam</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td>
                                                <t t-if="doc.tipe_peminjam == 'mahasiswa'">
                                                    <t t-esc="doc.mahasiswa_id.name"/> (<t t-esc="doc.mahasiswa_id.nim"/>)
                                                </t>
                                                <t t-elif="doc.tipe_peminjam == 'dosen'">
                                                    <t t-esc="doc.dosen_id.name"/> (<t t-esc="doc.dosen_id.nip"/>)
                                                </t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Jumlah Peserta</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="doc.jumlah_peserta"/> Orang</td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="width: 50%; vertical-align: top; padding: 2px 0;">
                                    <table>
                                        <tr>
                                            <td style="width: 120px; font-weight: bold;">Tanggal Mulai</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><span t-field="doc.tanggal_mulai"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Tanggal Selesai</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><span t-field="doc.tanggal_selesai"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold;">Status</td>
                                            <td style="padding: 0 6px;">:</td>
                                            <td><t t-esc="dict(doc._fields['state'].selection).get(doc.state)"/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- Keperluan -->
                        <div t-if="doc.keperluan" style="font-size: 10pt; margin-bottom: 16px;">
                            <p style="font-weight: bold; margin: 0 0 4px 0;">Keperluan:</p>
                            <p style="margin: 0; text-align: justify;"><t t-esc="doc.keperluan"/></p>
                        </div>

                        <!-- Tanda Tangan -->
                        <table style="width: 100%; margin-top: 40px; font-size: 10pt; text-align: center;">
                            <tr>
                                <td style="width: 50%;">
                                    Peminjam,
                                    <div style="margin-top: 60px;">
                                        <span style="font-weight: bold; border-top: 1px solid black; padding-top: 4px;">
                                            <t t-if="doc.tipe_peminjam == 'mahasiswa'"><t t-esc="doc.mahasiswa_id.name or '________________'"/></t>
                                            <t t-elif="doc.tipe_peminjam == 'dosen'"><t t-esc="doc.dosen_id.name or '________________'"/></t>
                                            <t t-else="">________________</t>
                                        </span>
                                    </div>
                                </td>
                                <td style="width: 50%;">
                                    Menyetujui,
                                    <div style="margin-top: 60px;">
                                        <span style="font-weight: bold; border-top: 1px solid black; padding-top: 4px;">
                                            <t t-esc="doc.status_changed_by_id.name or '________________'"/>
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
