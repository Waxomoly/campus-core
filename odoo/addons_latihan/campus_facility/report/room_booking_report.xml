<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_room_booking" model="ir.actions.report">
        <field name="name">Bukti Reservasi Ruangan</field>
        <field name="model">campus.room.booking</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">campus_facility.report_room_booking_doc</field>
        <field name="report_file">campus_facility.report_room_booking_doc</field>
        <field name="binding_model_id" ref="campus_facility.model_campus_room_booking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_room_booking_doc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center mt-4">BUKTI RESERVASI RUANGAN</h2>
                        <table class="table table-sm table-bordered mt-4">
                            <tr><th style="width:30%">Nomor Reservasi</th><td><span t-field="doc.name"/></td></tr>
                            <tr><th>Ruangan</th><td><span t-field="doc.room_id.name"/></td></tr>
                            <tr><th>Peminjam</th><td><span t-field="doc.mahasiswa_id.name"/> (<span t-field="doc.mahasiswa_id.nim"/>)</td></tr>
                            <tr><th>Keperluan</th><td><span t-field="doc.keperluan"/></td></tr>
                            <tr><th>Tanggal Mulai</th><td><span t-field="doc.tanggal_mulai"/></td></tr>
                            <tr><th>Tanggal Selesai</th><td><span t-field="doc.tanggal_selesai"/></td></tr>
                            <tr><th>Status</th><td><span t-field="doc.state"/></td></tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>