<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_booking" model="ir.actions.report">
        <field name="name">Bukti Booking</field>
        <field name="model">campus.facility.booking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">campus_facility.report_booking_document</field>
        <field name="report_file">campus_facility.report_booking_document</field>
        <field name="binding_model_id" ref="model_campus_facility_booking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_booking_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2 class="text-center">BUKTI BOOKING FASILITAS</h2>
                    <table class="table table-sm table-bordered mt-4">
                        <tr><th style="width:30%">Nomor Booking</th><td><span t-field="doc.name"/></td></tr>
                        <tr><th>Fasilitas</th><td><span t-field="doc.facility_id.name"/></td></tr>
                        <tr><th>Peminjam</th><td><span t-field="doc.mahasiswa_id.name"/> (<span t-field="doc.mahasiswa_id.nim"/>)</td></tr>
                        <tr><th>Keperluan</th><td><span t-field="doc.keperluan"/></td></tr>
                        <tr><th>Mulai</th><td><span t-field="doc.tanggal_mulai"/></td></tr>
                        <tr><th>Selesai</th><td><span t-field="doc.tanggal_selesai"/></td></tr>
                        <tr><th>Jumlah Peserta</th><td><span t-field="doc.jumlah_peserta"/></td></tr>
                        <tr><th>Status</th><td><span t-field="doc.state"/></td></tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
