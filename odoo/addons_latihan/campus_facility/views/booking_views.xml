<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_facility_booking_list" model="ir.ui.view">
        <field name="name">campus.facility.booking.list</field>
        <field name="model">campus.facility.booking</field>
        <field name="arch" type="xml">
            <list string="Booking">
                <field name="name"/>
                <field name="facility_id"/>
                <field name="peminjam_nama"/>
                <field name="kuantitas_pinjam"/>
                <field name="tanggal_mulai"/>
                <field name="tanggal_selesai"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_campus_facility_booking_form" model="ir.ui.view">
        <field name="name">campus.facility.booking.form</field>
        <field name="model">campus.facility.booking</field>
        <field name="arch" type="xml">
            <form string="Booking Fasilitas">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state == 'draft' or state=='approved'" groups="campus_facility.group_facility_manager"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state == 'draft' or state=='rejected'" groups="campus_facility.group_facility_manager"/>
                    <button name="action_reset" string="Set to Draft" type="object" invisible="state not in ('submitted', 'rejected') or created_by_id != uid"/>
                    <button name="%(action_report_facility_booking)d" string="Cetak" invisible="state != 'approved'" type="action" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="facility_id" readonly="state != 'draft'"/>

                            <field name="kuantitas_tersedia" readonly="True" invisible="state != 'draft'"/>

                            <field name="kuantitas_pinjam" readonly="state != 'draft'"/>
                            <field name="keperluan" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="tipe_peminjam"
                                   readonly="state != 'draft' or not is_facility_manager"
                                   invisible="not is_facility_manager"
                                   widget="radio" options="{'horizontal': true}"
                                   force_save="1"/>

                            <field name="mahasiswa_id"
                                   string="Peminjam"
                                   invisible="tipe_peminjam != 'mahasiswa'"
                                   required="tipe_peminjam == 'mahasiswa' and is_facility_manager"
                                   readonly="state != 'draft' or not is_facility_manager"/>

                            <field name="dosen_id"
                                   string="Peminjam"
                                   invisible="tipe_peminjam != 'dosen'"
                                   required="tipe_peminjam == 'dosen'"
                                   readonly="state != 'draft' or not is_facility_manager"/>

                            <field name="tanggal_mulai" readonly="state != 'draft'"/>
                            <field name="tanggal_selesai" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Informasi Log">
                        <field name="created_by_id" widget="many2one_avatar_user"/>
                        <field name="status_changed_by_id" widget="many2one_avatar_user"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_facility_booking_search" model="ir.ui.view">
        <field name="name">campus.facility.booking.search</field>
        <field name="model">campus.facility.booking</field>
        <field name="arch" type="xml">
            <search string="Cari Booking">
                <field name="name"/>
                <field name="facility_id"/>
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <group>
                    <filter name="group_facility" string="Fasilitas" context="{'group_by': 'facility_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_facility_booking" model="ir.actions.act_window">
        <field name="name">Booking Fasilitas</field>
        <field name="res_model">campus.facility.booking</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_campus_facility_booking" name="Booking Fasilitas"
              parent="menu_campus_root"
              action="action_campus_facility_booking" sequence="20"/>
</odoo>
