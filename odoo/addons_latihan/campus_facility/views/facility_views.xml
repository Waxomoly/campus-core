<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_facility_list" model="ir.ui.view">
        <field name="name">campus.facility.list</field>
        <field name="model">campus.facility</field>
        <field name="arch" type="xml">
            <list string="Fasilitas">
                <field name="kode"/>
                <field name="name"/>
                <field name="tipe_id"/>


                <field name="status" widget="badge"
                       decoration-success="status == 'Tersedia'"
                       decoration-danger="status == 'Maintenance'"/>
            </list>
        </field>
    </record>

    <record id="view_campus_facility_form" model="ir.ui.view">
        <field name="name">campus.facility.form</field>
        <field name="model">campus.facility</field>
        <field name="arch" type="xml">
            <form string="Fasilitas">
                <header>
                    <button name="action_set_maintenance" string="Set Maintenance" type="object" class="btn-danger" invisible="state == 'maintenance'" groups="campus_facility.group_facility_manager"/>
                    <button name="action_set_available" string="Set Tersedia" type="object" class="oe_highlight" invisible="state == 'tersedia'" groups="campus_facility.group_facility_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="tersedia,maintenance"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_booking" icon="fa-calendar">
                            <field name="booking_count" widget="statinfo" string="Booking"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="kode"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="tipe_id"/>
                            <field name="kuantitas"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Riwayat Booking" name="booking">
                            <field name="booking_ids" readonly="1">
                                <list>
                                    <field name="name" groups="campus_facility.group_facility_manager"/>
<!--                                    <field name="mahasiswa_id"-->
<!--                                           string="Peminjam"-->
<!--                                           groups="campus_facility.group_facility_manager"-->
<!--                                           invisible="tipe_peminjam == 'dosen'"/>-->

<!--                                    <field name="dosen_id"-->
<!--                                           string="Peminjam"-->
<!--                                           groups="campus_facility.group_facility_manager"-->
<!--                                           invisible="tipe_peminjam == 'mahasiswa'"/>-->

                                    <field name="peminjam_nama" string="Peminjam" groups="campus_facility.group_facility_manager"/>

                                    <field name="tanggal_mulai"/>
                                    <field name="tanggal_selesai"/>
                                    <field name="state" groups="campus_facility.group_facility_manager"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_facility_search" model="ir.ui.view">
        <field name="name">campus.facility.search</field>
        <field name="model">campus.facility</field>
        <field name="arch" type="xml">
            <search string="Cari Fasilitas">
                <field name="kode"/>
                <field name="name"/>
                <filter name="filter_tersedia" string="Tersedia" domain="[('state', '=', 'tersedia')]"/>
                <group>
                    <filter name="group_tipe" string="Tipe" context="{'group_by': 'tipe_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_facility" model="ir.actions.act_window">
        <field name="name">Fasilitas</field>
        <field name="res_model">campus.facility</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_campus_facility_type_form" model="ir.ui.view">
        <field name="name">campus.facility.type.form</field>
        <field name="model">campus.facility.type</field>
        <field name="arch" type="xml">
            <form string="Tipe Fasilitas">
                <sheet>

                    <field name="active" invisible="1"/>

                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <group>
                        <field name="active" invisible="1"/>
                        <field name="name" placeholder="Misal: Laboratorium"/>
                        <field name="code_prefix" placeholder="Misal: LAB"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_facility_type_search" model="ir.ui.view">
        <field name="name">campus.facility.type.search</field>
        <field name="model">campus.facility.type</field>
        <field name="arch" type="xml">
            <search string="Cari Tipe Fasilitas">
                <field name="name"/>
                <field name="code_prefix"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

<!--    <record id="action_campus_facility_type" model="ir.actions.act_window">-->
<!--        <field name="name">Tipe Fasilitas</field>-->
<!--        <field name="res_model">campus.facility.type</field>-->
<!--        <field name="view_mode">list,form</field>-->
<!--    </record>-->

