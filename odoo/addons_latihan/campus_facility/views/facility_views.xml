<!--              parent="menu_campus_facility_root"-->
<!--              action="action_campus_facility_type" sequence="30"/>-->

    <menuitem id="menu_campus_root" name="Fasilitas"
              parent="campus_core.menu_campus_root" sequence="30"/>
    <menuitem id="menu_campus_facility" name="Data Fasilitas"
              parent="menu_campus_root"
              action="action_campus_facility" sequence="10"/>
</odoo>
