<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_attendance" model="ir.actions.report">
        <field name="name">Rekap Absensi</field>
        <field name="model">campus.attendance.session</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">campus_attendance.report_attendance_document</field>
        <field name="report_file">campus_attendance.report_attendance_document</field>
        <field name="binding_model_id" ref="model_campus_attendance_session"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_attendance_document">
    <t t-call="web.html_container">
        <t t-call="web.internal_layout">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <!-- Judul -->
                    <div style="text-align: center; margin-bottom: 16px;">
                        <h2 style="margin: 0; font-size: 16pt; text-transform: uppercase;">
                            Rekap Absensi
                        </h2>
                        <p style="margin: 4px 0; font-size: 10pt; color: #555;">
                            <t t-esc="doc.name"/>
                        </p>
                    </div>

                    <!-- Info Header -->
                    <table style="width: 100%; font-size: 10pt; margin-bottom: 16px; border-collapse: collapse;">
                        <tr>
                            <td style="width: 50%; vertical-align: top; padding: 2px 0;">
                                <table>
                                    <tr>
                                        <td style="width: 120px; font-weight: bold;">Mata Kuliah</td>
                                        <td style="padding: 0 6px;">:</td>
                                        <td><t t-esc="doc.kelas_id.mata_kuliah_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: bold;">Kelas</td>
                                        <td style="padding: 0 6px;">:</td>
                                        <td><t t-esc="doc.kelas_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: bold;">Dosen</td>
                                        <td style="padding: 0 6px;">:</td>
                                        <td><t t-esc="doc.kelas_id.dosen_id.name or '-'"/></td>
                                    </tr>
                                </table>
                            </td>
                            <td style="width: 50%; vertical-align: top; padding: 2px 0;">
                                <table>
                                    <tr>
                                        <td style="width: 120px; font-weight: bold;">Tanggal</td>
                                        <td style="padding: 0 6px;">:</td>
                                        <td><span t-field="doc.tanggal" t-options='{"format": "dd MMMM yyyy"}'/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: bold;">Pertemuan Ke</td>
                                        <td style="padding: 0 6px;">:</td>
                                        <td><t t-esc="doc.pertemuan"/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: bold;">Jumlah Hadir</td>
                                        <td style="padding: 0 6px;">:</td>
                                        <td>
                                            <t t-esc="doc.jumlah_hadir"/> / <t t-esc="doc.jumlah_mahasiswa"/> mahasiswa
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- Tabel Absensi -->
                    <table style="width: 100%; border-collapse: collapse; font-size: 10pt;">
                        <thead>
                            <tr style="background-color: #2c3e50; color: white;">
                                <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 40px;">No</th>
                                <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: left; width: 100px;">NIM</th>
                                <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: left;">Nama Mahasiswa</th>
                                <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: center; width: 80px;">Status</th>
                                <th style="border: 1px solid #ccc; padding: 6px 8px; text-align: left;">Keterangan</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="doc.line_ids" t-as="line">
                                <tr t-attf-style="background-color: {{ 'white' if line_index % 2 == 0 else '#f9f9f9' }};">
                                    <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                        <t t-esc="line_index + 1"/>
                                    </td>
                                    <td style="border: 1px solid #ccc; padding: 5px 8px;">
                                        <t t-esc="line.mahasiswa_id.nim"/>
                                    </td>
                                    <td style="border: 1px solid #ccc; padding: 5px 8px;">
                                        <t t-esc="line.mahasiswa_id.name"/>
                                    </td>
                                    <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                        <t t-esc="line.status.capitalize()"/>
                                    </td>
                                    <td style="border: 1px solid #ccc; padding: 5px 8px;">
                                        <t t-esc="line.keterangan or '-'"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <!-- Footer rekap -->
                        <tfoot>
                            <tr style="background-color: #ecf0f1; font-weight: bold;">
                                <td colspan="3" style="border: 1px solid #ccc; padding: 5px 8px; text-align: right;">
                                    Total Hadir:
                                </td>
                                <td style="border: 1px solid #ccc; padding: 5px 8px; text-align: center;">
                                    <t t-esc="doc.jumlah_hadir"/>/<t t-esc="doc.jumlah_mahasiswa"/>
                                </td>
                                <td style="border: 1px solid #ccc;"/>
                            </tr>
                        </tfoot>
                    </table>

                    <!-- Tanda Tangan -->
                    <div style="margin-top: 40px; text-align: right; font-size: 10pt;">
                        <p style="margin: 0;">..................., <span t-field="doc.tanggal" t-options='{"format": "dd MMMM yyyy"}'/></p>
                        <p style="margin: 0; margin-top: 4px;">Dosen Pengampu,</p>
                        <div style="margin-top: 60px;">
                            <p style="margin: 0; font-weight: bold; border-top: 1px solid black; display: inline-block; min-width: 180px; text-align: center; padding-top: 4px;">
                                <t t-esc="doc.kelas_id.dosen_id.name or '________________'"/>
                            </p>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </t>
</template>
</odoo>
