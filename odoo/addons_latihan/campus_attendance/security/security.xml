<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_attendance_manager" model="res.groups.privilege">
        <field name="name">Attendance Access</field>
        <field name="category_id" ref="campus_core.module_category_campus"/>
        <field name="placeholder">Non-Manager</field>
    </record>

    <record id="group_attendance_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_attendance_manager"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Dosen: hanya bisa lihat & kelola sesi kelas miliknya -->
    <record id="rule_attendance_session_dosen" model="ir.rule">
        <field name="name">Sesi Absensi: Dosen hanya kelas miliknya</field>
        <field name="model_id" ref="model_campus_attendance_session"/>
        <field name="groups" eval="[(4, ref('campus_core.group_campus_lecturer'))]"/>
        <field name="domain_force">[('kelas_id.dosen_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Manager: bisa lihat & kelola semua sesi -->
    <record id="rule_attendance_session_manager" model="ir.rule">
        <field name="name">Sesi Absensi: Manager semua kelas</field>
        <field name="model_id" ref="model_campus_attendance_session"/>
        <field name="groups" eval="[(4, ref('group_attendance_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- Mahasiswa: hanya bisa lihat baris absensi miliknya sendiri -->
    <record id="rule_attendance_line_mahasiswa" model="ir.rule">
        <field name="name">Absensi Line: Mahasiswa hanya miliknya</field>
        <field name="model_id" ref="model_campus_attendance_line"/>
        <field name="groups" eval="[(4, ref('campus_core.group_campus_student'))]"/>
        <field name="domain_force">[('mahasiswa_id.user_id', '=', user.id)]</field>
    </record>

    <record id="rule_attendance_line_dosen" model="ir.rule">
        <field name="name">Absensi Line: Dosen kelas miliknya</field>
        <field name="model_id" ref="model_campus_attendance_line"/>
        <field name="groups" eval="[(4, ref('campus_core.group_campus_lecturer'))]"/>
        <field name="domain_force">
            [('session_id.kelas_id.dosen_id.user_id', '=', user.id)]
        </field>
    </record>

    <record id="rule_attendance_line_manager" model="ir.rule">
        <field name="name">Absensi Line: Manager semua data</field>
        <field name="model_id" ref="model_campus_attendance_line"/>
        <field name="groups" eval="[(4, ref('group_attendance_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
