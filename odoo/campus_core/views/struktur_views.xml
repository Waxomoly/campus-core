<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- FAKULTAS  (level 1)                                          -->
    <!-- ============================================================ -->
    <record id="view_campus_fakultas_list" model="ir.ui.view">
        <field name="name">campus.fakultas.list</field>
        <field name="model">campus.fakultas</field>
        <field name="arch" type="xml">
            <list string="Daftar Fakultas">
                <field name="kode"/>
                <field name="name"/>
                <field name="prodi_count"/>
                <field name="jurusan_count"/>
            </list>
        </field>
    </record>

    <record id="view_campus_fakultas_form" model="ir.ui.view">
        <field name="name">campus.fakultas.form</field>
        <field name="model">campus.fakultas</field>
        <field name="arch" type="xml">
            <form string="Form Fakultas">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nama Fakultas"/></h1>
                    </div>
                    <group>
                        <field name="kode"/>
                    </group>
                    <notebook>
                        <page string="Program Studi" name="prodi">
                            <field name="prodi_ids">
                                <list editable="bottom">
                                    <field name="kode"/>
                                    <field name="name"/>
                                    <field name="jenjang"/>
                                    <field name="jurusan_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_campus_fakultas" model="ir.actions.act_window">
        <field name="name">Fakultas</field>
        <field name="res_model">campus.fakultas</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================================================ -->
    <!-- PROGRAM STUDI  (level 2)                                     -->
    <!-- ============================================================ -->
    <record id="view_campus_prodi_list" model="ir.ui.view">
        <field name="name">campus.prodi.list</field>
        <field name="model">campus.prodi</field>
        <field name="arch" type="xml">
            <list string="Daftar Program Studi">
                <field name="kode"/>
                <field name="name"/>
                <field name="jenjang"/>
                <field name="fakultas_id"/>
                <field name="jurusan_count"/>
            </list>
        </field>
    </record>

    <record id="view_campus_prodi_form" model="ir.ui.view">
        <field name="name">campus.prodi.form</field>
        <field name="model">campus.prodi</field>
        <field name="arch" type="xml">
            <form string="Form Program Studi">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nama Program Studi"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="kode"/>
                            <field name="jenjang"/>
                        </group>
                        <group>
                            <field name="fakultas_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Jurusan" name="jurusan">
                            <field name="jurusan_ids">
                                <list editable="bottom">
                                    <field name="kode"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_prodi_search" model="ir.ui.view">
        <field name="name">campus.prodi.search</field>
        <field name="model">campus.prodi</field>
        <field name="arch" type="xml">
            <search string="Cari Prodi">
                <field name="name"/>
                <field name="kode"/>
                <field name="fakultas_id"/>
                <group>
                    <filter name="group_fakultas" string="Fakultas" context="{'group_by': 'fakultas_id'}"/>
                    <filter name="group_jenjang" string="Jenjang" context="{'group_by': 'jenjang'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_prodi" model="ir.actions.act_window">
        <field name="name">Program Studi</field>
        <field name="res_model">campus.prodi</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================================================ -->
    <!-- JURUSAN  (level 3 / leaf)                                    -->
    <!-- ============================================================ -->
    <record id="view_campus_jurusan_list" model="ir.ui.view">
        <field name="name">campus.jurusan.list</field>
        <field name="model">campus.jurusan</field>
        <field name="arch" type="xml">
            <list string="Daftar Jurusan">
                <field name="kode"/>
                <field name="name"/>
                <field name="prodi_id"/>
                <field name="fakultas_id"/>
            </list>
        </field>
    </record>

    <record id="view_campus_jurusan_form" model="ir.ui.view">
        <field name="name">campus.jurusan.form</field>
        <field name="model">campus.jurusan</field>
        <field name="arch" type="xml">
            <form string="Form Jurusan">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nama Jurusan"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="kode"/>
                            <field name="prodi_id"/>
                        </group>
                        <group>
                            <field name="fakultas_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_jurusan_search" model="ir.ui.view">
        <field name="name">campus.jurusan.search</field>
        <field name="model">campus.jurusan</field>
        <field name="arch" type="xml">
            <search string="Cari Jurusan">
                <field name="name"/>
                <field name="kode"/>
                <field name="prodi_id"/>
                <field name="fakultas_id"/>
                <group>
                    <filter name="group_fakultas" string="Fakultas" context="{'group_by': 'fakultas_id'}"/>
                    <filter name="group_prodi" string="Prodi" context="{'group_by': 'prodi_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_jurusan" model="ir.actions.act_window">
        <field name="name">Jurusan</field>
        <field name="res_model">campus.jurusan</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================================================ -->
    <!-- MENUS  (urutan: Fakultas -> Prodi -> Jurusan)               -->
    <!-- ============================================================ -->
    <menuitem id="menu_campus_struktur" name="Struktur Kampus"
              parent="menu_campus_master" sequence="1"/>
    <menuitem id="menu_campus_fakultas" name="Fakultas"
              parent="menu_campus_struktur" action="action_campus_fakultas" sequence="10"/>
    <menuitem id="menu_campus_prodi" name="Program Studi"
              parent="menu_campus_struktur" action="action_campus_prodi" sequence="20"/>
    <menuitem id="menu_campus_jurusan" name="Jurusan"
              parent="menu_campus_struktur" action="action_campus_jurusan" sequence="30"/>
</odoo>
