<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kategori + Privilege "Campus Role": membuat Student & Lecturer tampil
         sebagai SATU pilihan role (dropdown) di form User, bukan checkbox
         terpisah. Dengan begitu satu user hanya bisa Student ATAU Lecturer.
         (Odoo 19: res.groups pakai privilege_id, bukan category_id.) -->
    <record id="module_category_campus" model="ir.module.category">
        <field name="name">Campus</field>
        <field name="sequence">20</field>
    </record>

    <record id="privilege_campus_role" model="res.groups.privilege">
        <field name="name">Campus Role</field>
        <field name="category_id" ref="module_category_campus"/>
        <field name="placeholder">Bukan pengguna Campus</field>
        <field name="sequence">10</field>
    </record>

    <!-- Role: Mahasiswa (Student) -->
    <record id="group_campus_student" model="res.groups">
        <field name="name">Campus / Student (Mahasiswa)</field>
        <field name="privilege_id" ref="privilege_campus_role"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Role: Dosen / Pembimbing Akademik (Lecturer) -->
    <record id="group_campus_lecturer" model="res.groups">
        <field name="name">Campus / Lecturer (Dosen Pembimbing)</field>
        <field name="privilege_id" ref="privilege_campus_role"/>
        <field name="implied_ids" eval="[(4, ref('group_campus_student'))]"/>
    </record>
</odoo>
