<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_booking_list" model="ir.ui.view">
        <field name="name">campus.room.booking.list</field>
        <field name="model">campus.room.booking</field>
        <field name="arch" type="xml">
            <list string="Booking">
                <field name="name"/>
                <field name="room_id"/>
                <field name="mahasiswa_id"/>
                <field name="tanggal_mulai"/>
                <field name="tanggal_selesai"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_campus_booking_form" model="ir.ui.view">
        <field name="name">campus.room.booking.form</field>
        <field name="model">campus.room.booking</field>
        <field name="arch" type="xml">
            <form string="Booking Ruangan">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="campus_facility.group_facility_manager"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state != 'submitted'" groups="campus_facility.group_facility_manager"/>
                    <button name="action_reset" string="Set to Draft" type="object" invisible="state not in ('submitted', 'rejected')"/>
                    <button name="%(action_report_room_booking)d" string="Cetak" invisible="state != 'approved'" type="action" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="room_id" readonly="state != 'draft'"/>
                            <field name="mahasiswa_id" readonly="state != 'draft'" domain="[('status', '=', 'aktif')]"/>
                            <field name="keperluan" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="tanggal_mulai" readonly="state != 'draft'"/>
                            <field name="tanggal_selesai" readonly="state != 'draft'"/>
                            <field name="jumlah_peserta" readonly="state != 'draft'"/>
                            <field name="kapasitas"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_booking_search" model="ir.ui.view">
        <field name="name">campus.room.booking.search</field>
        <field name="model">campus.room.booking</field>
        <field name="arch" type="xml">
            <search string="Cari Booking">
                <field name="name"/>
                <field name="room_id"/>
                <field name="mahasiswa_id"/>
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <group>
                    <filter name="group_room" string="Ruangan" context="{'group_by': 'room_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_room_booking" model="ir.actions.act_window">
        <field name="name">Booking Ruangan</field>
        <field name="res_model">campus.room.booking</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_campus_room_booking" name="Booking Ruangan"
              parent="menu_campus_root"
              action="action_campus_room_booking" sequence="20"/>
</odoo>
