<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_campus_room_type_list" model="ir.ui.view">
        <field name="name">campus.room.type.list</field>
        <field name="model">campus.room.type</field>
        <field name="arch" type="xml">
            <list string="Tipe Ruangan">
                <field name="name"/>
                <field name="code_prefix"/>
            </list>
        </field>
    </record>

    <record id="view_campus_room_type_form" model="ir.ui.view">
        <field name="name">campus.room.type.form</field>
        <field name="model">campus.room.type</field>
        <field name="arch" type="xml">
            <form string="Tipe Ruangan">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <group>
                        <field name="active" invisible="1"/>
                        <field name="name"/>
                        <field name="code_prefix"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_campus_room_type" model="ir.actions.act_window">
        <field name="name">Tipe Ruangan</field>
        <field name="res_model">campus.room.type</field>
        <field name="view_mode">list,form</field>
    </record>


    <menuitem id="menu_campus_room_type" name="Tipe Ruangan"
              parent="menu_campus_root"
              groups="campus_facility.group_facility_manager"
              action="action_campus_room_type" sequence="40"/>
</odoo>
