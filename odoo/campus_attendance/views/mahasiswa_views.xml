<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_mahasiswa_form_attendance" model="ir.ui.view">
        <field name="name">campus.mahasiswa.form.attendance</field>
        <field name="model">campus.mahasiswa</field>
        <field name="inherit_id" ref="campus_core.view_campus_mahasiswa_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button" type="object"
                            name="action_view_attendance" icon="fa-check-square-o">
                        <field name="attendance_count" widget="statinfo" string="Absensi"/>
                    </button>
            </xpath>
            <xpath expr="//sheet/group[1]" position="before">
                <div class="alert alert-warning" role="alert" invisible="not warning_kehadiran">
                    Peringatan: Persentase kehadiran mahasiswa ini di bawah 75%!
                </div>
            </xpath>
            <xpath expr="//sheet/group[1]" position="after">
                <group string="Rekap Kehadiran">
                    <field name="persentase_kehadiran"/>
                    <field name="warning_kehadiran"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
